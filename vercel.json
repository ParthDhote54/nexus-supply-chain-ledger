{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "functions": {
    "api/index.mjs": {
      "includeFiles": "dist/server/**"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/api/index.mjs" },
    {
      "source": "/((?!assets/|.*\\.[a-zA-Z0-9]+$).*)",
      "destination": "/api/index.mjs"
    }
  ]
}
